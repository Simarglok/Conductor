# Conductor Backend — Environment Variables
# Copy this file to .env and adjust for your setup.
#
# cp backend/.env.example backend/.env
#
# docker-compose loads backend/.env automatically via env_file.

# ── Database ──
# Default: postgresql+asyncpg://conductor:conductor@postgres:5432/conductor
CONDUCTOR_DATABASE_URL=postgresql+asyncpg://conductor:conductor@postgres:5432/conductor

# ── Redis ──
# Default: redis://redis:6379/1 (DB 1 — Airflow uses DB 0)
CONDUCTOR_REDIS_URL=redis://redis:6379/1

# ── Auth ──
# JWT signing key — change in production!
CONDUCTOR_SECRET_KEY=dev-secret-change-in-production

# Dedicated key for encrypting Git tokens and other stored credentials (32+ characters).
# Keep this stable: changing it makes existing encrypted credentials unreadable.
CONDUCTOR_CREDENTIALS_ENCRYPTION_KEY=dev-credentials-key-change-in-production

# JWT algorithm (default: HS256)
CONDUCTOR_ALGORITHM=HS256

# Access token expiry in minutes (default: 60)
CONDUCTOR_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Destructive-action re-authentication (secure defaults shown)
CONDUCTOR_REAUTH_GRANT_TTL_SECONDS=300
CONDUCTOR_REAUTH_RATE_LIMIT_ATTEMPTS=5
CONDUCTOR_REAUTH_RATE_LIMIT_WINDOW_SECONDS=300
# Comma-separated IP CIDRs for reverse proxies allowed to supply X-Forwarded-For.
# The secure fallback trusts loopback only. Add only the exact egress CIDR(s) of
# your Vite/ingress proxy; never configure all RFC1918/private address space.
CONDUCTOR_TRUSTED_PROXY_CIDRS=127.0.0.0/8,::1/128

# ── Durable lifecycle worker ──
# Polling, lease/heartbeat, and bounded exponential retry defaults.
CONDUCTOR_LIFECYCLE_WORKER_POLL_SECONDS=1.0
CONDUCTOR_LIFECYCLE_WORKER_LEASE_SECONDS=30
CONDUCTOR_LIFECYCLE_WORKER_HEARTBEAT_SECONDS=10.0
CONDUCTOR_LIFECYCLE_RETRY_BASE_SECONDS=5.0
CONDUCTOR_LIFECYCLE_RETRY_CAP_SECONDS=300.0
CONDUCTOR_LIFECYCLE_RETRY_JITTER_SECONDS=1.0

# ── Airflow (will be wired later) ──
CONDUCTOR_AIRFLOW_BASE_URL=http://airflow-api-server:8080

# ── Workspace (code-server) ──
CONDUCTOR_CODE_SERVER_HOST=http://code-server:8080
CONDUCTOR_CODE_SERVER_JWT_SECRET=conductor-cs-jwt-secret-change-in-prod
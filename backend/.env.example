# Conductor Backend — Environment Variables
# Copy this file to .env and adjust for your setup.
#
# cp backend/.env.example backend/.env
#
# docker-compose loads backend/.env automatically via env_file.

# ── Database ──
# Default: postgresql+asyncpg://conductor:conductor@postgres:5432/conductor
CONDUCTOR_DATABASE_URL=postgresql+asyncpg://conductor:conductor@postgres:5432/conductor

# ── Redis ──
# Default: redis://redis:6379/1 (DB 1 — Airflow uses DB 0)
CONDUCTOR_REDIS_URL=redis://redis:6379/1

# ── Auth ──
# JWT signing key — change in production!
CONDUCTOR_SECRET_KEY=dev-secret-change-in-production

# JWT algorithm (default: HS256)
CONDUCTOR_ALGORITHM=HS256

# Access token expiry in minutes (default: 60)
CONDUCTOR_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Airflow (will be wired later) ──
CONDUCTOR_AIRFLOW_BASE_URL=http://airflow-api-server:8080

# ── Workspace (code-server) ──
CONDUCTOR_CODE_SERVER_HOST=http://code-server:8080
CONDUCTOR_CODE_SERVER_JWT_SECRET=conductor-cs-jwt-secret-change-in-prod